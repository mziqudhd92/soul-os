{
  "name": "@soulos/sdk",
  "version": "0.1.0",
  "description": "TypeScript client for SoulOS — avatars, episodic memory, SSE chat (@soulos/sdk)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mziqudhd92/soul-os.git",
    "directory": "packages/soulos-sdk/ts"
  },
  "homepage": "https://github.com/mziqudhd92/soul-os#readme",
  "keywords": [
    "soulos",
    "ai-agents",
    "mcp",
    "sse",
    "chatbot",
    "hexaco"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "dependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
