# SoulOS environment — copy to .env and uncomment the plug-in block you need

# --- Kernel ---
DATABASE_URL=postgresql+asyncpg://postgres:changeme_local_dev@db:5432/senticore
INFERENCE_API_URL=http://ollama:11434
EMBEDDING_DIMENSION=768
INFERENCE_SKIP_PULL=0
INFERENCE_MODE=full
MODEL_NAME=llama3
EMBED_MODEL_NAME=nomic-embed-text

# --- Plug-in: Docker + Ollama (default) ---
# docker compose --profile ollama up
# INFERENCE_API_URL=http://ollama:11434
# EMBEDDING_DIMENSION=768
# INFERENCE_SKIP_PULL=0

# --- Plug-in: inference bridge mock (CI / no GPU) ---
# docker compose --profile bridge-mock up
# INFERENCE_API_URL=http://soulos-inference-bridge:11434
# BRIDGE_MODE=mock
# EMBEDDING_DIMENSION=768
# INFERENCE_SKIP_PULL=1

# --- Plug-in: AWS Bedrock via bridge ---
# docker compose --profile bridge-aws up
# INFERENCE_API_URL=http://soulos-inference-bridge:11434
# BRIDGE_MODE=bedrock
# EMBEDDING_DIMENSION=1024
# INFERENCE_SKIP_PULL=1
# MODEL_NAME=amazon.nova-lite-v1:0
# EMBED_MODEL_NAME=amazon.titan-embed-text-v2:0
# AWS_REGION=us-east-1
# BEDROCK_CHAT_MODEL_ID=amazon.nova-lite-v1:0
# BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# --- Plug-in: GCP Vertex via bridge ---
# docker compose --profile bridge-vertex up
# INFERENCE_API_URL=http://soulos-inference-bridge:11434
# BRIDGE_MODE=vertex
# EMBEDDING_DIMENSION=768
# INFERENCE_SKIP_PULL=1
# MODEL_NAME=gemini-2.0-flash-001
# EMBED_MODEL_NAME=text-embedding-004
# VERTEX_PROJECT_ID=your-gcp-project
# VERTEX_LOCATION=us-central1
# VERTEX_CHAT_MODEL=gemini-2.0-flash-001
# VERTEX_EMBED_MODEL=text-embedding-004
