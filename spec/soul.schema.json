{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulos.dev/schemas/soul.schema.json",
  "title": "SoulOS Soul File",
  "description": "Personality specification for a SoulOS avatar (.soul.json validated fields). Unified .soul files compile to this shape; runtime_config (dual_process thresholds) is stored on the bot row outside this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "role", "description", "attachment_style", "baseline_msv"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Human-readable avatar name."
    },
    "role": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Short title describing the avatar's function."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Foundational system prompt: beliefs, tone, and boundaries."
    },
    "attachment_style": {
      "type": "string",
      "enum": ["Secure", "Anxious-Preoccupied", "Dismissive-Avoidant"],
      "description": "Relational dynamics when the user is critical, cold, or demanding."
    },
    "baseline_msv": {
      "$ref": "#/$defs/MetacognitiveStateVector"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Optional skill tags for marketplace or routing."
    },
    "hourly_rate": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional marketplace hourly rate."
    },
    "status": {
      "type": "string",
      "enum": ["available", "busy", "offline"],
      "description": "Optional availability status."
    },
    "avatar_url": {
      "type": "string",
      "format": "uri",
      "description": "Optional avatar image URL."
    }
  },
  "$defs": {
    "HexacoTraits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["H", "E", "X", "A", "C", "O"],
      "properties": {
        "H": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Honesty-Humility"
        },
        "E": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Emotionality"
        },
        "X": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "eXtraversion"
        },
        "A": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Agreeableness"
        },
        "C": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Conscientiousness"
        },
        "O": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Openness to Experience"
        }
      }
    },
    "MoralFoundations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "care_harm",
        "fairness_cheating",
        "loyalty_betrayal",
        "authority_subversion",
        "sanctity_degradation"
      ],
      "properties": {
        "care_harm": { "type": "number", "minimum": 0, "maximum": 1 },
        "fairness_cheating": { "type": "number", "minimum": 0, "maximum": 1 },
        "loyalty_betrayal": { "type": "number", "minimum": 0, "maximum": 1 },
        "authority_subversion": { "type": "number", "minimum": 0, "maximum": 1 },
        "sanctity_degradation": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "IntrinsicDrives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["curiosity", "autonomy", "social_approval"],
      "properties": {
        "curiosity": { "type": "number", "minimum": 0, "maximum": 1 },
        "autonomy": { "type": "number", "minimum": 0, "maximum": 1 },
        "social_approval": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "MetacognitiveStateVector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hexaco",
        "moral_foundations",
        "drives",
        "epistemic_uncertainty",
        "inner_monologue"
      ],
      "properties": {
        "hexaco": { "$ref": "#/$defs/HexacoTraits" },
        "moral_foundations": { "$ref": "#/$defs/MoralFoundations" },
        "drives": { "$ref": "#/$defs/IntrinsicDrives" },
        "epistemic_uncertainty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence or conflict about the current context."
        },
        "inner_monologue": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "One-sentence internal state at boot."
        }
      }
    }
  }
}
