{
  "name": "soulos-monorepo",
  "version": "0.1.0",
  "description": "SoulOS — open-source runtime for persistent AI avatars (HEXACO MSV, episodic memory, MCP, Soul Studio)",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mziqudhd92/soul-os.git"
  },
  "homepage": "https://mziqudhd92.github.io/soul-os/",
  "bugs": {
    "url": "https://github.com/mziqudhd92/soul-os/issues"
  },
  "keywords": [
    "soulos",
    "ai-agents",
    "mcp",
    "hexaco",
    "psychometrics",
    "fastapi",
    "pgvector",
    "chatbot",
    "episodic-memory",
    "cursor",
    "claude",
    "sse",
    "rag",
    "open-source"
  ],
  "workspaces": [
    "packages/soulos-sdk/ts"
  ],
  "scripts": {
    "test:all": "npm run test:kernel && npm run test:gateway && npm run test:studio",
    "test:kernel": "cd packages/soulos-core && (test -x .venv/bin/pytest && .venv/bin/pytest -q || python3 -m pytest -q)",
    "test:gateway": "cd packages/soulos-gateway && python3 -m pytest -q",
    "test:studio": "cd packages/soulos-studio && (test -x .venv/bin/pytest && .venv/bin/pytest -q || python3 -m pytest -q)",
    "cloud:up": "docker compose -f docker-compose.cloud.yml up --build",
    "up": "docker compose up --build",
    "studio": "soulos-studio",
    "build:sdk": "npm run build -w @soulos/sdk",
    "seed": "python3 scripts/seed.py",
    "doc:gen": "python3 scripts/doc-gen/generate_docs.py",
    "build:tutorials-site": "python3 scripts/build-studio-tutorials-site.py --out site --base /soul-os/"
  }
}
